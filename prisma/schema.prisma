// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("USER") // ADMIN, USER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  leads         Lead[]
}

model Lead {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  status        String    @default("NEW") // NEW, PROCESSING, QUOTED, PAID, SHIPPED, DELIVERED
  productName   String
  productUrl    String?
  quantity      Int       @default(1)
  targetPrice   Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  quotes        Quote[]
  tags          Tag[]
}

model Quote {
  id                String    @id @default(cuid())
  leadId            String
  lead              Lead      @relation(fields: [leadId], references: [id])
  sourcingPrice     Float
  shippingCost      Float
  serviceFee        Float
  totalLandedCost   Float
  estimatedDelivery String?
  notes             String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String    @db.Text
  targetKeyword  String?
  metaDescription String?
  lang           String    @default("en") // en, pl, de, fr
  status         String    @default("DRAFT") // DRAFT, PUBLISHED
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  leads Lead[]
}

model AdminAction {
  id        String   @id @default(cuid())
  type      String   // E.g., "EMAIL_SENT", "STATUS_CHANGE", "CAMPAIGN_CREATED"
  details   String?  // Description or target lead
  adminId   String?
  adminName String   @default("System")
  createdAt DateTime @default(now())
}

model ColdOutreach {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  subject   String
  body      String   @db.Text
  lang      String   @default("en")
  status    String   @default("SENT") // SENT, FAILED
  sentAt    DateTime @default(now())

  @@index([sentAt, status])
}

model Unsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Tracks every email delivery event received from Resend webhooks
model EmailEvent {
  id        String   @id @default(cuid())
  resendId  String   // Resend email ID
  type      String   // DELIVERED, BOUNCED, SPAM, OPENED, CLICKED
  toEmail   String
  subject   String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([toEmail])
}

// Tracks SEO indexing status of published blog posts
model SeoCheck {
  id          String   @id @default(cuid())
  postId      String
  slug        String
  lang        String
  indexed     Boolean  @default(false)
  checkedAt   DateTime @default(now())
  searchSnippet String? // excerpt from search result if found

  @@index([slug, lang])
}
